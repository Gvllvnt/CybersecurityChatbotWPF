<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔒 Cybersecurity Awareness Bot - Part 3" 
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D44" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🔒 CYBERSECURITY AWARENESS BOT 🔒" 
                           FontSize="28" FontWeight="Bold" 
                           Foreground="#00D4FF" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Protecting South Africans Online - Part 3" 
                           FontSize="14" 
                           Foreground="#AAAAAA" 
                           HorizontalAlignment="Center" 
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Background="#2D2D44" BorderThickness="0">

            <!-- Tab 1: Chat -->
            <TabItem Header="💬 Chat" Background="#2D2D44" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="#1E1E2E" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                            <RichTextBox x:Name="ChatDisplay" 
                                         Background="#1E1E2E" 
                                         Foreground="White" 
                                         BorderThickness="0"
                                         FontSize="14"
                                         IsReadOnly="True">
                                <RichTextBox.Resources>
                                    <Style TargetType="{x:Type Paragraph}">
                                        <Setter Property="Margin" Value="0,0,0,5"/>
                                    </Style>
                                </RichTextBox.Resources>
                            </RichTextBox>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="1" Background="#2D2D44" CornerRadius="10" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="UserInput" 
                                     Grid.Column="0"
                                     Background="#1E1E2E" 
                                     Foreground="White"
                                     BorderThickness="0"
                                     FontSize="14"
                                     Padding="10"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Center"
                                     KeyDown="UserInput_KeyDown"/>

                            <Button x:Name="SendButton" 
                                    Grid.Column="1"
                                    Content="Send" 
                                    Width="80"
                                    Height="40"
                                    Margin="10,0,0,0"
                                    Background="#00D4FF" 
                                    Foreground="Black"
                                    FontWeight="Bold"
                                    FontSize="14"
                                    BorderThickness="0"
                                    Click="SendButton_Click"
                                    Cursor="Hand"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: Tasks -->
            <TabItem Header="📋 Tasks" Background="#2D2D44" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E1E2E" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="📋 Your Cybersecurity Tasks" 
                                       FontSize="18" FontWeight="Bold" 
                                       Foreground="#00D4FF"/>
                            <TextBlock Text="Add, track, and complete your cybersecurity tasks" 
                                       FontSize="12" 
                                       Foreground="#AAAAAA"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="TaskList" 
                                 Background="#1E1E2E" 
                                 Foreground="White"
                                 BorderThickness="0"
                                 FontSize="14"
                                 Margin="0,0,0,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2D2D44" CornerRadius="5" Padding="10" Margin="0,0,0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="#00D4FF"/>
                                            <TextBlock Text="{Binding Description}" Foreground="#AAAAAA" FontSize="12"/>
                                            <TextBlock Text="{Binding Status}" Foreground="#888888" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#2D2D44" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Add New Task" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TaskInput" 
                                         Grid.Column="0"
                                         Background="#1E1E2E" 
                                         Foreground="White"
                                         BorderThickness="0"
                                         FontSize="14"
                                         Padding="10"
                                         TextWrapping="Wrap"/>
                                <Button x:Name="AddTaskButton" 
                                        Grid.Column="1"
                                        Content="Add" 
                                        Width="60"
                                        Height="35"
                                        Margin="10,0,0,0"
                                        Background="#00D4FF" 
                                        Foreground="Black"
                                        FontWeight="Bold"
                                        Click="AddTaskButton_Click"
                                        Cursor="Hand"/>
                            </Grid>
                            <TextBlock x:Name="TaskStatus" Foreground="#888888" FontSize="11" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 3: Quiz -->
            <TabItem Header="🎮 Quiz" Background="#2D2D44" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E1E2E" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🎮 Cybersecurity Quiz" 
                                       FontSize="18" FontWeight="Bold" 
                                       Foreground="#00D4FF"/>
                            <TextBlock Text="Test your cybersecurity knowledge!" 
                                       FontSize="12" 
                                       Foreground="#AAAAAA"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <RichTextBox x:Name="QuizDisplay" 
                                     Background="#1E1E2E" 
                                     Foreground="White"
                                     BorderThickness="0"
                                     FontSize="14"
                                     IsReadOnly="True">
                            <RichTextBox.Resources>
                                <Style TargetType="{x:Type Paragraph}">
                                    <Setter Property="Margin" Value="0,0,0,10"/>
                                </Style>
                            </RichTextBox.Resources>
                        </RichTextBox>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#2D2D44" CornerRadius="10" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="QuizInput" 
                                     Grid.Column="0"
                                     Background="#1E1E2E" 
                                     Foreground="White"
                                     BorderThickness="0"
                                     FontSize="14"
                                     Padding="10"
                                     KeyDown="QuizInput_KeyDown"/>
                            <Button x:Name="QuizSendButton" 
                                    Grid.Column="1"
                                    Content="Answer" 
                                    Width="70"
                                    Height="35"
                                    Margin="10,0,0,0"
                                    Background="#FF6B6B" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Click="QuizSendButton_Click"
                                    Cursor="Hand"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 4: Activity Log -->
            <TabItem Header="📝 Activity Log" Background="#2D2D44" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E1E2E" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="📝 Activity Log" 
                                       FontSize="18" FontWeight="Bold" 
                                       Foreground="#00D4FF"/>
                            <TextBlock Text="Recent actions and activities" 
                                       FontSize="12" 
                                       Foreground="#AAAAAA"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="ActivityLogList" 
                                 Background="#1E1E2E" 
                                 Foreground="White"
                                 BorderThickness="0"
                                 FontSize="13">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2D2D44" CornerRadius="5" Padding="10" Margin="0,0,0,3">
                                        <TextBlock Text="{Binding}" Foreground="#AAAAAA"/>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#2D2D44" CornerRadius="10" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="RefreshLogButton" 
                                    Grid.Column="0"
                                    Content="🔄 Refresh" 
                                    Width="100"
                                    Height="35"
                                    Background="#00D4FF" 
                                    Foreground="Black"
                                    FontWeight="Bold"
                                    Click="RefreshLogButton_Click"
                                    Cursor="Hand"/>
                            <Button x:Name="ClearLogButton" 
                                    Grid.Column="1"
                                    Content="🗑️ Clear" 
                                    Width="80"
                                    Height="35"
                                    Margin="10,0,0,0"
                                    Background="#FF6B6B" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Click="ClearLogButton_Click"
                                    Cursor="Hand"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
