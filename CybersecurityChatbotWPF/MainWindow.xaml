<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D44" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="🔒 CYBERSECURITY AWARENESS BOT 🔒" 
                   FontSize="28" FontWeight="Bold" 
                   Foreground="#00D4FF" 
                   HorizontalAlignment="Center"/>
                <TextBlock Text="Protecting South Africans Online" 
                   FontSize="16" 
                   Foreground="#AAAAAA" 
                   HorizontalAlignment="Center" 
                   Margin="0,5,0,0"/>
                <TextBlock Text="═══════════════════════════════════════════════" 
                   FontSize="14" 
                   Foreground="#444466" 
                   HorizontalAlignment="Center" 
                   Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Chat Display -->
        <Border Grid.Row="2" Background="#2D2D44" CornerRadius="10" Padding="10" Margin="0,0,0,15">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled">
                <RichTextBox x:Name="ChatDisplay" 
                             Background="#2D2D44" 
                             Foreground="White" 
                             BorderThickness="0"
                             FontSize="14"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto">
                    <RichTextBox.Resources>
                        <Style TargetType="{x:Type Paragraph}">
                            <Setter Property="Margin" Value="0,0,0,5"/>
                        </Style>
                    </RichTextBox.Resources>
                </RichTextBox>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="3" Background="#2D2D44" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInput" 
                         Grid.Column="0"
                         Background="#1E1E2E" 
                         Foreground="White"
                         BorderThickness="0"
                         FontSize="14"
                         Padding="10"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Center"
                         KeyDown="UserInput_KeyDown">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="Send" 
                        Width="80"
                        Height="40"
                        Margin="10,0,0,0"
                        Background="#00D4FF" 
                        Foreground="Black"
                        FontWeight="Bold"
                        FontSize="14"
                        BorderThickness="0"
                        Click="SendButton_Click"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="Transparent" Padding="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="StatusText" 
                           Text="Ready to help you stay safe online!" 
                           Foreground="#888888" 
                           FontSize="12"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
